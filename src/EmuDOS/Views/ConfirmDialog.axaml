<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EmuDOS.Views.ConfirmDialog"
        WindowDecorations="None" CanResize="False" SizeToContent="Height" Width="400"
        Background="{StaticResource BgPrimary}" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
  <Border BorderBrush="{StaticResource BorderNormal}" BorderThickness="1">
    <StackPanel Margin="24,22">
      <TextBlock Name="TitleText" Foreground="{StaticResource TextPrimary}"
                 FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
      <TextBlock Name="MessageText" Foreground="{StaticResource TextSecondary}"
                 TextWrapping="Wrap" Margin="0,0,0,20"/>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="Cancel" Click="OnCancel" Padding="18,6"/>
        <Button Name="ConfirmBtn" Content="OK" Click="OnConfirm" Margin="10,0,0,0"
                Padding="18,6" Foreground="{StaticResource Accent}"/>
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
