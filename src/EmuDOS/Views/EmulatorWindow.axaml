<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EmuDOS.Views.EmulatorWindow"
        Title="EmuDOS" Width="800" Height="640"
        Icon="/Assets/emudos-linux.png"
        Background="Black" WindowStartupLocation="CenterScreen">
  <Grid>
    <Image Name="Screen" Stretch="Uniform" RenderOptions.BitmapInterpolationMode="None"/>
    <TextBlock Name="FpsOverlay" IsVisible="True" IsHitTestVisible="False"
               HorizontalAlignment="Left" VerticalAlignment="Top" Margin="14"
               Foreground="#7CFC7C" FontFamily="monospace" FontSize="14" FontWeight="Bold"
               Background="#A0000000" Padding="8,3" Text="FPS …"/>
    <!-- Recording indicator (top-right red dot + REC), shown while a capture is running. -->
    <Border Name="RecIndicator" IsVisible="False" IsHitTestVisible="False"
            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="14"
            Background="#A0000000" CornerRadius="4" Padding="8,3">
      <StackPanel Orientation="Horizontal">
        <Ellipse Width="10" Height="10" Fill="#E03535" VerticalAlignment="Center"/>
        <TextBlock Text="REC" Margin="6,0,0,0" Foreground="White" FontFamily="monospace"
                   FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
      </StackPanel>
    </Border>
    <!-- Transient hint toast (mouse lock, save state, screenshot, etc.). -->
    <TextBlock Name="Hint" IsVisible="False" IsHitTestVisible="False"
               HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,28"
               Foreground="White" FontSize="14" FontWeight="SemiBold"
               Background="#C0000000" Padding="14,7" TextAlignment="Center"/>
  </Grid>
</Window>
