<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EmuDOS.Views.ImageViewerWindow"
        Title="Extras" Height="720" Width="960"
        WindowStartupLocation="CenterOwner"
        Background="#0E0E0E"
        Icon="/Assets/emudos-linux.png"
        KeyDown="OnKeyDown">
  <Grid>
    <Image Name="Pic" Stretch="Uniform" Margin="12,12,12,40" RenderOptions.BitmapInterpolationMode="HighQuality"/>

    <Button Content="‹" Click="OnPrev" Width="44" Height="80" FontSize="30" Foreground="White"
            Background="#55000000" BorderThickness="0" Cursor="Hand"
            HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,0,0,0"/>
    <Button Content="›" Click="OnNext" Width="44" Height="80" FontSize="30" Foreground="White"
            Background="#55000000" BorderThickness="0" Cursor="Hand"
            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0"/>

    <TextBlock Name="Caption" HorizontalAlignment="Center" VerticalAlignment="Bottom"
               Margin="0,0,0,12" Foreground="#CFCFCF" FontSize="13"/>
  </Grid>
</Window>
