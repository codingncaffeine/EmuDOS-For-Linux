<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EmuDOS.App"
             RequestedThemeVariant="Dark">
  <Application.Styles>
    <FluentTheme />
  </Application.Styles>
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="/Themes/Theme.axaml" />
        <ResourceInclude Source="/Themes/Controls.axaml" />
      </ResourceDictionary.MergedDictionaries>
      <!-- Drive Fluent's accent (selection, focus, ComboBox highlight) with the EmuDOS red. -->
      <Color x:Key="SystemAccentColor">#E03535</Color>
      <Color x:Key="SystemAccentColorDark1">#E03535</Color>
      <Color x:Key="SystemAccentColorLight1">#E03535</Color>
    </ResourceDictionary>
  </Application.Resources>
</Application>
